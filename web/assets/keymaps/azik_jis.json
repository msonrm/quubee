    "tr": "たら",
    "bt": "びと",
    "dt": "だち",
    "ms": "ます",
    "dm": "でも",
    "nr": "なる",
    "mt": "また",
    "gr": "がら",
    "wr": "われ",
    "ht": "ひと",
    "ds": "です",
    "kr": "から",
    "yr": "よる",
    "tb": "たび",
    "gt": "ごと",
    "_comment_azik_foreign": "AZIK 固有の外来音ショートカット",
    "tgi": "てぃ",
