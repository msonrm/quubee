# Emscripten build output
/build/

# Generated Wasm artifacts (produced by emscripten/build.sh)
/web/np2kai_core.js
/web/np2kai_core.wasm

# デプロイ用に生成する静的ディレクトリ (tools/deploy.sh の出力)
/dist/

# wrangler のローカルキャッシュ/状態
/.wrangler/

# NP2kai build artifacts
/core/np2kai/build/

# MIDI soundfont (GeneralUser GS、~32MB)。tools/setup_soundfont.sh で取得、リポジトリには含めない
# (font.bmp と違い大きいので。デプロイ時 deploy.sh が同梱、ブラウザは遅延 on-demand で fetch)
/web/assets/soundfont.sf2
/web/assets/soundfont.sf2.*
# freepats (旧 GUS パッチセット、~33MB)。MIDI 合成は TinySoundFont+SF2 に移行済で現在は未使用
/web/assets/freepats/

# ゲーム書庫 (.lzh/.zip/.rar 等) と派生イメージ。
# 著作権者から再配布許可を得ていないため、公開リポジトリ (github.com) には含めない。
# 検証用に「こちら側」(ローカル) のみ保持する。games/ 配下は .gitkeep を除き全て無視。
/games/*
!/games/.gitkeep

# tools/dos_loader の派生物 (build.sh の出力)。
# web/assets/loader.d88 はコミット (ブラウザが fetch するため)。
/tools/dos_loader/boot.bin
/tools/dos_loader/loader.d88
/tools/dos_loader/hello.com
/tools/dos_loader/args.com
/tools/dos_loader/hello.exe
/tools/dos_loader/sjistest.com
/tools/dos_loader/dostest.com
/tools/dos_loader/shell.bin
# ↑ shell.bin は中間生成物。C ビルド用の native/dos_shell_blob.h (build.sh 生成) はコミットする。

# フォント配布アーカイブ (参照用・大きい。ライセンス文は CREDITS.md に取り込み済み)
/sazanami-fontbmp.zip

# Python __pycache__
__pycache__/
*.pyc

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# font_build: ビルド時依存と中間生成物 (最終成果物は web/assets/font.bmp、package-lock.json は追跡)
/tools/font_build/node_modules/
/tools/font_build/font.bmp

# debug/作業用スクリーンショット (ユーザ共有のため一時的に置く)
/Screenshot*.png

# Mozc-Wasm (HLE FEP のかな漢字変換エンジン、BSD-3)。~/development/mozc-wasm-build/ でビルド
# (レシピは同ディレクトリ README.md)。辞書 mozc.data は fcitx-contrib/fcitx5-mozc release 由来。
# ブラウザは FEP 初回 ON 時に遅延 fetch。deploy.sh が dist へ同梱する
/web/assets/mozc_qb.js
/web/assets/mozc_qb.wasm
/web/assets/mozc.data
/tools/mcp/node_modules/
/tools/mcp/package-lock.json
