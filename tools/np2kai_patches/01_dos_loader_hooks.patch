 #if defined(BIOS_IO_EMULATION)
 	UINT32	oldEIP;
@@ -1172,6 +1185,37 @@ UINT MEMCALL biosfunc(UINT32 adrs) {
 			CPU_REMCLOCK -= 2000;
 			bootstrapload();
 			return(0);
+
+		/* ---- Phase 3 ミニマル DOS ローダ (qb 拡張) ---- */
+		/* 番地は linear address (= F000:EExx)。native/dos_loader.h の QB_TRAMP_* と揃える */
+		case 0xFEE00:  /* loader-start: boot sector が far jmp で踏む */
+			CPU_REMCLOCK -= 200;
+			return qb_dos_loader_start_hook();
+
+		case 0xFEE10:  /* INT 21h ディスパッチャ */
+			CPU_REMCLOCK -= 50;
+			return qb_dos_int21_hook();
+
+		case 0xFEE20:  /* INT 20h (DOS exit ショートカット) */
+			CPU_REMCLOCK -= 50;
+			return qb_dos_int20_hook();
+
+		/* ---- qb: XMS/EMS 需要プローブ (検出ログのみ、応答は未実装=無しを維持) ---- */
+		case 0xFEE50:  /* INT 2Fh (XMS インストールチェック AX=43xx) */
+			CPU_REMCLOCK -= 50;
+			return qb_dos_int2f_hook();
+
+		case 0xFEE60:  /* INT 67h (EMS) */
+			CPU_REMCLOCK -= 50;
+			return qb_dos_int67_hook();
+
+		case 0xFEE70:  /* XMS (HIMEM 相当) ドライバ entry (far CALL) */
+			CPU_REMCLOCK -= 50;
+			return qb_dos_xms_entry_hook();
+
+		case 0xFEE80:  /* INT 29h (DOS 高速文字出力) — AL を tty へ (master.lib text_clear=ESC[2J) */
+			CPU_REMCLOCK -= 50;
+			return qb_dos_int29_hook();
 	}
 
