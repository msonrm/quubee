--- a/bios/bios.c
+++ b/bios/bios.c
@@ -410,6 +410,20 @@ static void setbiosseed(UINT8 *ptr, UINT size, UINT seedpos) {
 	ptr[seedpos + 1] -= y;
 }
 
+/* Phase 3 DOS ローダ (qb 拡張) — native/dos_loader.c & native/dos_int21.c が定義 */
+extern int qb_dos_loader_start_hook(void);
+extern int qb_dos_int21_hook(void);
+extern int qb_dos_int20_hook(void);
+extern int qb_dos_int2f_hook(void);   /* qb: XMS インストールチェック (INT 2Fh AX=43xx, Tier1 実装済・有効時は応答) */
+extern int qb_dos_int67_hook(void);   /* qb: EMS 需要プローブ (INT 67h, 未実装=不在を返す) */
+extern int qb_dos_xms_entry_hook(void); /* qb: XMS (HIMEM 相当) ドライバ entry */
+extern int qb_dos_int29_hook(void);   /* qb: INT 29h (DOS 高速文字出力, master.lib text_clear 用) */
+extern int qb_dos_batch_next_hook(void); /* qb: .bat 文インタプリタ「次コマンド?」(シェルの far CALL) */
+extern int qb_dos_intdc_hook(void);   /* qb: INT DCh (PC-98 ファンクション/編集キー定義 BIOS) */
+extern int qb_dos_int27_hook(void);   /* qb: INT 27h (Terminate and Stay Resident, 旧式 TSR — MS Mouse 等) */
+extern int qb_dos_int18_hook(void);   /* qb: INT 18h (CRT BIOS) 30 行モード時フロントエンド (30BIOS-API + パススルー) */
+extern void qb_dos_install_trampolines(void);
+
 void bios_initialize(void) {
 
 	BOOL	biosrom;
@@ -463,6 +477,11 @@ void bios_initialize(void) {
 		CopyMemory(mem + 0x0e8000, nosyscode, sizeof(nosyscode));
 		if ((!biosrom) && (!(pccore.model & PCMODEL_EPSON))) {
 			CopyMemory(mem + 0xe8dd8, neccheck, 0x25);
+			/* QB: 実機 N88-BASIC ROM 同様に先頭 4KB 内へ "NEC N-88BASIC(86)" を置く。
+			 * Turbo-C BGI 等が E800:0000-0FFF を "NEC N-88" でスキャンして NEC 実機
+			 * 判定するため (Epson チェックの変種、life100 -egc の grNotDetected 根治)。
+			 * 番地は neccheck (E800:0DD8) 直前の未使用域。setbiosseed より前に書く。 */
+			CopyMemory(mem + 0xe8dc0, "NEC N-88BASIC(86)", 17);
 			pos = LOADINTELWORD(itfrom + 2);
 			CopyMemory(mem + 0xf538e, itfrom + pos, 0x27);
 		}
@@ -517,6 +536,9 @@ void bios_initialize(void) {
 	mem[0xffff0] = 0xea;
 	STOREINTELDWORD(mem + 0xffff1, 0xfd800000);
 
+	/* Phase 3 ローダ (qb 拡張) — トランポリン (0xFEE00 以降、詳細は dos_loader.h) を仕込む */
+	qb_dos_install_trampolines();
+
 	CopyMemory(mem + 0x0fd800 + 0x0e00, keytable[0], 0x60 * 8);
 	
 	//fh = file_create_c(_T("emuitf.rom"));
@@ -911,7 +933,7 @@ void biosioemu_proc(void) {
 UINT MEMCALL biosfunc(UINT32 adrs) {
 
 	UINT16	bootseg;
-	
+
 // np21w ver0.86 rev46 BIOS I/O emulation
 #if defined(BIOS_IO_EMULATION)
 	UINT32	oldEIP;
@@ -1172,6 +1194,53 @@ UINT MEMCALL biosfunc(UINT32 adrs) {
 			CPU_REMCLOCK -= 2000;
 			bootstrapload();
 			return(0);
+
+		/* ---- Phase 3 ミニマル DOS ローダ (qb 拡張) ---- */
+		/* 番地は linear address (= F000:EExx)。native/dos_loader.h の QB_TRAMP_* と揃える */
+		case 0xFEE00:  /* loader-start: boot sector が far jmp で踏む */
+			CPU_REMCLOCK -= 200;
+			return qb_dos_loader_start_hook();
+
+		case 0xFEE10:  /* INT 21h ディスパッチャ */
+			CPU_REMCLOCK -= 50;
+			return qb_dos_int21_hook();
+
+		case 0xFEE20:  /* INT 20h (DOS exit ショートカット) */
+			CPU_REMCLOCK -= 50;
+			return qb_dos_int20_hook();
+
+		/* ---- qb: XMS は Tier1 実装 (有効時は INT 2Fh に応答)、EMS は需要プローブのみ (不在を返す) ---- */
+		case 0xFEE50:  /* INT 2Fh (XMS インストールチェック AX=43xx) */
+			CPU_REMCLOCK -= 50;
+			return qb_dos_int2f_hook();
+
+		case 0xFEE60:  /* INT 67h (EMS) */
+			CPU_REMCLOCK -= 50;
+			return qb_dos_int67_hook();
+
+		case 0xFEE70:  /* XMS (HIMEM 相当) ドライバ entry (far CALL) */
+			CPU_REMCLOCK -= 50;
+			return qb_dos_xms_entry_hook();
+
+		case 0xFEE80:  /* INT 29h (DOS 高速文字出力) — AL を tty へ (master.lib text_clear=ESC[2J) */
+			CPU_REMCLOCK -= 50;
+			return qb_dos_int29_hook();
+
+		case 0xFEE90:  /* .bat 文インタプリタ「次コマンド?」 (ミニ COMMAND.COM の far CALL) */
+			CPU_REMCLOCK -= 50;
+			return qb_dos_batch_next_hook();
+
+		case 0xFEEA0:  /* INT DCh (PC-98 ファンクション/編集キー定義 BIOS) — VZ Editor 等 */
+			CPU_REMCLOCK -= 50;
+			return qb_dos_intdc_hook();
+
+		case 0xFEEB0:  /* INT 27h (Terminate and Stay Resident, 旧式 TSR) — MS Mouse 等 */
+			CPU_REMCLOCK -= 50;
+			return qb_dos_int27_hook();
+
+		case 0xFEEC0:  /* INT 18h フロントエンド (30 行モード時のみ) — 30BIOS-API + bios0x18 パススルー */
+			CPU_REMCLOCK -= 200;
+			return qb_dos_int18_hook();
 	}
 
 	if ((adrs >= 0xf9950) && (adrs <= 0x0f9990) && (!(adrs & 3))) {
