-	volM = np2cfg.vol_master;
+
+	volM = np2cfg.vol_master * g_qb_beep_gain / 100;	/* qb: BEEP 専用ゲイン (上記) */
 
 	vol = beepcfg.vol;
 	bev = bp->event;
