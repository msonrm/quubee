@@ -447,6 +447,160 @@ extern UINT32		opCache;
 #define	CPU_INPADRS	i386core.e.inport
 #define	CPU_EMSPTR	i386core.e.ems
 
+/* ---- QuuBee patch 07: 物理メモリ fast path (inline) ----
+ * CPU からのアクセスの大半は「conventional RAM (< 0xA0000/0xA4000)」か「拡張メモリ」だが、
+ * 従来は毎バイト別翻訳単位の memp_*() 呼び出し + if チェーンだった。RAM 区間だけを
+ * 呼び出し元へインライン展開し、それ以外 (VRAM/ROM/15-16MB ホール/9821 領域) は
+ * 従来関数へフォールバックする。拡張メモリの窓は memp_*() のチェーンと同じ 2 つ:
+ *   [USE_HIMEM, CPU_EXTLIMIT16)  … 1MB 強〜最大 15MB
+ *   [0x1000000, CPU_EXTLIMIT)    … 16MB〜 (DOS/4GW は 32MB 機だと最大連続ブロックが
+ *                                   16MB 以上に取れるため、ここにコードが載る。実測
+ *                                   Suika3 は命令フェッチの 98% がこの窓だった)
+ * 境界値 (read=CPU_MEMREADMAX, write=CPU_MEMWRITEMAX, 16/32bit は -1/-3)・A20 マスク・
+ * write8 の 0x457 (IDE ワークアラウンド) の意味論は memp_*() の先頭 fast path と同一。
+ * 拡張メモリの 16/32bit は 32KB 境界でもバンク切替が無いため直ロードとバイト合成は同値。
+ * CPU_EXTLIMIT16/CPU_EXTLIMIT は ia32_setextsize() で常に >= 0x100000 なので
+ * -1/-3 がアンダーフローすることはない。 */
+#include "cpumem.h"
+
+STATIC_INLINE REG8 qb_phys_read8(UINT32 address) {
+	UINT32 madr;
+	if (address < CPU_MEMREADMAX)
+		return mem[address];
+	madr = address & CPU_ADRSMASK;
+	if (madr >= USE_HIMEM) {
+		if (madr < CPU_EXTLIMIT16)
+			return CPU_EXTMEMBASE[madr];
+		if (madr >= 0x01000000 && madr < CPU_EXTLIMIT)
+			return CPU_EXTMEMBASE[madr];
+	}
+	return memp_read8(address);
+}
+STATIC_INLINE REG16 qb_phys_read16(UINT32 address) {
+	UINT32 madr;
+	if (address < (CPU_MEMREADMAX - 1))
+		return (REG16)(LOADINTELWORD(mem + address));
+	madr = address & CPU_ADRSMASK;
+	if (madr >= USE_HIMEM) {
+		if (madr < (CPU_EXTLIMIT16 - 1))
+			return (REG16)(LOADINTELWORD(CPU_EXTMEMBASE + madr));
+		if (madr >= 0x01000000 && madr < (CPU_EXTLIMIT - 1))
+			return (REG16)(LOADINTELWORD(CPU_EXTMEMBASE + madr));
+	}
+	return memp_read16(address);
+}
+STATIC_INLINE UINT32 qb_phys_read32(UINT32 address) {
+	UINT32 madr;
+	if (address < (CPU_MEMREADMAX - 3))
+		return LOADINTELDWORD(mem + address);
+	madr = address & CPU_ADRSMASK;
+	if (madr >= USE_HIMEM) {
+		if (madr < (CPU_EXTLIMIT16 - 3))
+			return LOADINTELDWORD(CPU_EXTMEMBASE + madr);
+		if (madr >= 0x01000000 && madr < (CPU_EXTLIMIT - 3))
+			return LOADINTELDWORD(CPU_EXTMEMBASE + madr);
+	}
+	return memp_read32(address);
+}
+STATIC_INLINE void qb_phys_write8(UINT32 address, REG8 value) {
+	UINT32 madr;
+	if (address < CPU_MEMWRITEMAX) {
+		if (address != 0x0457)	/* IDE データ破壊回避 (memp_write8 と同一) */
+			mem[address] = (UINT8)value;
+		return;
+	}
+	madr = address & CPU_ADRSMASK;
+	if (madr >= USE_HIMEM) {
+		if (madr < CPU_EXTLIMIT16) {
+			CPU_EXTMEMBASE[madr] = (UINT8)value;
+			return;
+		}
+		if (madr >= 0x01000000 && madr < CPU_EXTLIMIT) {
+			CPU_EXTMEMBASE[madr] = (UINT8)value;
+			return;
+		}
+	}
+	memp_write8(address, value);
+}
+STATIC_INLINE void qb_phys_write16(UINT32 address, REG16 value) {
+	UINT32 madr;
+	if (address < (CPU_MEMWRITEMAX - 1)) {
+		STOREINTELWORD(mem + address, value);
+		return;
+	}
+	madr = address & CPU_ADRSMASK;
+	if (madr >= USE_HIMEM) {
+		if (madr < (CPU_EXTLIMIT16 - 1)) {
+			STOREINTELWORD(CPU_EXTMEMBASE + madr, value);
+			return;
+		}
+		if (madr >= 0x01000000 && madr < (CPU_EXTLIMIT - 1)) {
+			STOREINTELWORD(CPU_EXTMEMBASE + madr, value);
+			return;
+		}
+	}
+	memp_write16(address, value);
+}
+STATIC_INLINE void qb_phys_write32(UINT32 address, UINT32 value) {
+	UINT32 madr;
+	if (address < (CPU_MEMWRITEMAX - 3)) {
+		STOREINTELDWORD(mem + address, value);
+		return;
+	}
+	madr = address & CPU_ADRSMASK;
+	if (madr >= USE_HIMEM) {
+		if (madr < (CPU_EXTLIMIT16 - 3)) {
+			STOREINTELDWORD(CPU_EXTMEMBASE + madr, value);
+			return;
+		}
+		if (madr >= 0x01000000 && madr < (CPU_EXTLIMIT - 3)) {
+			STOREINTELDWORD(CPU_EXTMEMBASE + madr, value);
+			return;
+		}
+	}
+	memp_write32(address, value);
+}
+STATIC_INLINE PF_UINT8 qb_phys_read8_codefetch(UINT32 address) {
+	UINT32 madr;
+	if (address < CPU_MEMREADMAX)
+		return mem[address];
+	madr = address & CPU_ADRSMASK;
+	if (madr >= USE_HIMEM) {
+		if (madr < CPU_EXTLIMIT16)
+			return CPU_EXTMEMBASE[madr];
+		if (madr >= 0x01000000 && madr < CPU_EXTLIMIT)
+			return CPU_EXTMEMBASE[madr];
+	}
+	return memp_read8_codefetch(address);
+}
+STATIC_INLINE PF_UINT16 qb_phys_read16_codefetch(UINT32 address) {
+	UINT32 madr;
+	if (address < (CPU_MEMREADMAX - 1))
+		return (PF_UINT16)(LOADINTELWORD(mem + address));
+	madr = address & CPU_ADRSMASK;
+	if (madr >= USE_HIMEM) {
+		if (madr < (CPU_EXTLIMIT16 - 1))
+			return (PF_UINT16)(LOADINTELWORD(CPU_EXTMEMBASE + madr));
+		if (madr >= 0x01000000 && madr < (CPU_EXTLIMIT - 1))
+			return (PF_UINT16)(LOADINTELWORD(CPU_EXTMEMBASE + madr));
+	}
+	return memp_read16_codefetch(address);
+}
+STATIC_INLINE PF_UINT32 qb_phys_read32_codefetch(UINT32 address) {
+	UINT32 madr;
+	if (address < (CPU_MEMREADMAX - 3))
+		return LOADINTELDWORD(mem + address);
+	madr = address & CPU_ADRSMASK;
+	if (madr >= USE_HIMEM) {
+		if (madr < (CPU_EXTLIMIT16 - 3))
+			return LOADINTELDWORD(CPU_EXTMEMBASE + madr);
+		if (madr >= 0x01000000 && madr < (CPU_EXTLIMIT - 3))
+			return LOADINTELDWORD(CPU_EXTMEMBASE + madr);
+	}
+	return memp_read32_codefetch(address);
+}
+/* ---- QuuBee patch 07 ここまで (命令フェッチ側は本ファイル末尾) ---- */
+
 extern sigjmp_buf	exec_1step_jmpbuf;
 
 /*
@@ -1477,4 +1631,174 @@ char *cpu_disasm2str(UINT32 eip);
 #include "resolve.h"
 #include "task.h"
 
+/* ---- QuuBee patch 07: 命令フェッチ fast path (inline 版 cpu_codefetch) ----
+ * 全命令フェッチは ia32.mcr の GET_PC* マクロ経由でここを通る (直接呼び出しは
+ * IA32_INSTRUCTION_TRACE のみ)。out-of-line の cpu_codefetch* (cpu_mem.c) と
+ * 分岐構造・#GP 例外・リミット比較 (w=-1, d=-3) は同一で、物理アクセスだけ
+ * qb_phys_*_codefetch でインライン化している。EXCEPTION/CPU_PAGE_* が要るため
+ * exception.h / paging.h の include より後に置く。 */
+STATIC_INLINE PF_UINT8 qb_codefetch(UINT32 offset)
+{
+	descriptor_t *sdp = &CPU_CS_DESC;
+	UINT32 addr = sdp->u.seg.segbase + offset;
+
+	if (!CPU_STAT_PM)
+		return qb_phys_read8_codefetch(addr);
+	if (offset <= sdp->u.seg.limit) {
+		if (!CPU_STAT_PAGING)
+			return qb_phys_read8_codefetch(addr);
+		return cpu_linear_memory_read_b_codefetch(addr,
+		    CPU_PAGE_READ_CODE | CPU_STAT_USER_MODE);
+	}
+	EXCEPTION(GP_EXCEPTION, 0);
+	return 0;	/* compiler happy */
+}
+STATIC_INLINE PF_UINT16 qb_codefetch_w(UINT32 offset)
+{
+	descriptor_t *sdp = &CPU_CS_DESC;
+	UINT32 addr = sdp->u.seg.segbase + offset;
+
+	if (!CPU_STAT_PM)
+		return qb_phys_read16_codefetch(addr);
+	if (offset <= sdp->u.seg.limit - 1) {
+		if (!CPU_STAT_PAGING)
+			return qb_phys_read16_codefetch(addr);
+		return cpu_linear_memory_read_w_codefetch(addr,
+		    CPU_PAGE_READ_CODE | CPU_STAT_USER_MODE);
+	}
+	EXCEPTION(GP_EXCEPTION, 0);
+	return 0;	/* compiler happy */
+}
+STATIC_INLINE PF_UINT32 qb_codefetch_d(UINT32 offset)
+{
+	descriptor_t *sdp = &CPU_CS_DESC;
+	UINT32 addr = sdp->u.seg.segbase + offset;
+
+	if (!CPU_STAT_PM)
+		return qb_phys_read32_codefetch(addr);
+	if (offset <= sdp->u.seg.limit - 3) {
+		if (!CPU_STAT_PAGING)
+			return qb_phys_read32_codefetch(addr);
+		return cpu_linear_memory_read_d_codefetch(addr,
+		    CPU_PAGE_READ_CODE | CPU_STAT_USER_MODE);
+	}
+	EXCEPTION(GP_EXCEPTION, 0);
+	return 0;	/* compiler happy */
+}
+/* ---- QuuBee patch 07 ここまで ---- */
+
+/* ---- QuuBee patch 08: 実モードの data access / segreg load fast path ----
+ * 16bit 実モードゲーム (Ray 等) は cpu_vmemoryread_w / load_segreg (LES 連発) が
+ * プロファイル上位に来る。!CPU_STAT_PM 分岐 (cpu_mem.mcr / segments.c と逐語同一) を
+ * 呼び出し元へインライン化し、PM は従来の out-of-line へフォールバックする。
+ * cpu_mem.c 自身は QB_CPU_MEM_IMPL を定義してマクロ差し替えを受けない
+ * (本体定義がリネームされて衝突するのを防ぐ)。 */
+STATIC_INLINE UINT8 qb_vmemoryread_b(int idx, UINT32 offset) {
+	if (!CPU_STAT_PM)
+		return (UINT8)qb_phys_read8(CPU_STAT_SREG(idx).u.seg.segbase + offset);
+	return cpu_vmemoryread_b(idx, offset);
+}
+STATIC_INLINE UINT16 qb_vmemoryread_w(int idx, UINT32 offset) {
+	if (!CPU_STAT_PM)
+		return (UINT16)qb_phys_read16(CPU_STAT_SREG(idx).u.seg.segbase + offset);
+	return cpu_vmemoryread_w(idx, offset);
+}
+STATIC_INLINE UINT32 qb_vmemoryread_d(int idx, UINT32 offset) {
+	if (!CPU_STAT_PM)
+		return qb_phys_read32(CPU_STAT_SREG(idx).u.seg.segbase + offset);
+	return cpu_vmemoryread_d(idx, offset);
+}
+STATIC_INLINE void qb_vmemorywrite_b(int idx, UINT32 offset, UINT8 value) {
+	if (!CPU_STAT_PM) {
+		qb_phys_write8(CPU_STAT_SREG(idx).u.seg.segbase + offset, value);
+		return;
+	}
+	cpu_vmemorywrite_b(idx, offset, value);
+}
+STATIC_INLINE void qb_vmemorywrite_w(int idx, UINT32 offset, UINT16 value) {
+	if (!CPU_STAT_PM) {
+		qb_phys_write16(CPU_STAT_SREG(idx).u.seg.segbase + offset, value);
+		return;
+	}
+	cpu_vmemorywrite_w(idx, offset, value);
+}
+STATIC_INLINE void qb_vmemorywrite_d(int idx, UINT32 offset, UINT32 value) {
+	if (!CPU_STAT_PM) {
+		qb_phys_write32(CPU_STAT_SREG(idx).u.seg.segbase + offset, value);
+		return;
+	}
+	cpu_vmemorywrite_d(idx, offset, value);
+}
+STATIC_INLINE UINT32 qb_vmemory_RMW_b(int idx, UINT32 offset, UINT32 (CPUCALL *func)(UINT32, void *), void *arg) {
+	if (!CPU_STAT_PM) {
+		UINT32 addr = CPU_STAT_SREG(idx).u.seg.segbase + offset;
+		UINT8 value = (UINT8)qb_phys_read8(addr);
+		UINT32 result = (*func)(value, arg);
+		qb_phys_write8(addr, (UINT8)result);
+		return value;
+	}
+	return cpu_vmemory_RMW_b(idx, offset, func, arg);
+}
+STATIC_INLINE UINT32 qb_vmemory_RMW_w(int idx, UINT32 offset, UINT32 (CPUCALL *func)(UINT32, void *), void *arg) {
+	if (!CPU_STAT_PM) {
+		UINT32 addr = CPU_STAT_SREG(idx).u.seg.segbase + offset;
+		UINT16 value = (UINT16)qb_phys_read16(addr);
+		UINT32 result = (*func)(value, arg);
+		qb_phys_write16(addr, (UINT16)result);
+		return value;
+	}
+	return cpu_vmemory_RMW_w(idx, offset, func, arg);
+}
+STATIC_INLINE UINT32 qb_vmemory_RMW_d(int idx, UINT32 offset, UINT32 (CPUCALL *func)(UINT32, void *), void *arg) {
+	if (!CPU_STAT_PM) {
+		UINT32 addr = CPU_STAT_SREG(idx).u.seg.segbase + offset;
+		UINT32 value = qb_phys_read32(addr);
+		UINT32 result = (*func)(value, arg);
+		qb_phys_write32(addr, result);
+		return value;
+	}
+	return cpu_vmemory_RMW_d(idx, offset, func, arg);
+}
+#if !defined(QB_CPU_MEM_IMPL)
+#define	cpu_vmemoryread_b(i,o)		qb_vmemoryread_b(i,o)
+#define	cpu_vmemoryread_w(i,o)		qb_vmemoryread_w(i,o)
+#define	cpu_vmemoryread_d(i,o)		qb_vmemoryread_d(i,o)
+#define	cpu_vmemorywrite_b(i,o,v)	qb_vmemorywrite_b(i,o,v)
+#define	cpu_vmemorywrite_w(i,o,v)	qb_vmemorywrite_w(i,o,v)
+#define	cpu_vmemorywrite_d(i,o,v)	qb_vmemorywrite_d(i,o,v)
+#define	cpu_vmemory_RMW_b(i,o,f,a)	qb_vmemory_RMW_b(i,o,f,a)
+#define	cpu_vmemory_RMW_w(i,o,f,a)	qb_vmemory_RMW_w(i,o,f,a)
+#define	cpu_vmemory_RMW_d(i,o,f,a)	qb_vmemory_RMW_d(i,o,f,a)
+#endif
+
+/* segreg load: 実モード/VM86 は segments.c load_segreg の該当分岐 +
+ * segdesc_set_default の逐語インライン (書き込むフィールドも同一。唯一の差は
+ * 未使用パディング u.seg.d_pad に「スタックごみ」でなく旧値が残ること)。 */
+STATIC_INLINE void qb_load_segreg(int idx, UINT16 selector, UINT16 *sregp, descriptor_t *sdp, int exc) {
+	if (!CPU_STAT_PM || CPU_STAT_VM86) {
+		*sregp = selector;
+		sdp->u.seg.segbase = (UINT32)selector << 4;
+		sdp->u.seg.limit = 0xffff;
+		sdp->u.seg.c = (idx == CPU_CS_INDEX) ? 1 : 0;
+		sdp->u.seg.g = 0;
+		sdp->u.seg.wr = 1;
+		sdp->u.seg.ec = 0;
+		sdp->valid = 1;
+		sdp->p = 1;
+		sdp->type = (CPU_SEGDESC_TYPE_WR << CPU_DESC_H_TYPE_SHIFT)
+		            | ((idx == CPU_CS_INDEX) ? CPU_SEGDESC_H_D_C : 0);
+		sdp->dpl = CPU_STAT_VM86 ? 3 : 0;
+		sdp->rpl = CPU_STAT_VM86 ? 3 : 0;
+		sdp->s = 1;
+		sdp->d = 0;
+		sdp->flag = CPU_DESC_FLAG_READABLE|CPU_DESC_FLAG_WRITABLE;
+		return;
+	}
+	load_segreg(idx, selector, sregp, sdp, exc);
+}
+#undef	LOAD_SEGREG1
+#define	LOAD_SEGREG1(idx, selector, e) \
+	qb_load_segreg(idx, selector, &CPU_REGS_SREG(idx), &CPU_STAT_SREG(idx), e)
+/* ---- QuuBee patch 08 ここまで ---- */
+
 #endif	/* !IA32_CPU_CPU_H__ */
